ANTHROPIC_API_KEY=your-anthropic-key
OPENAI_API_KEY=your-openai-key
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook
DISCORD_WEBHOOK_USERNAME=Hermes Pipeline
PLANNER_PROVIDER=openai
PLANNER_MODEL=gpt-5.4
EXECUTOR_PROVIDER=openai
EXECUTOR_MODEL=gpt-5.4
REVIEWER_PROVIDER=openai
REVIEWER_MODEL=gpt-5.4
CROSS_VERIFIER_PROVIDER=anthropic
CROSS_VERIFIER_MODEL=claude-opus-4-6
ANTHROPIC_THINKING_ENABLED=true
ANTHROPIC_THINKING_TYPE=adaptive
ANTHROPIC_THINKING_BUDGET_TOKENS=2000
PIPELINE_DB_PATH=outputs/pipeline.db
